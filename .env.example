# Database
DB_PASSWORD=lingo

# Service authentication (shared secret between Node and Python services)
SERVICE_SECRET=changeme

# LLM backend for battle question generation
# Options: anthropic | ollama | none
# Use "none" for local dev without LLM (fallback questions will be used)
LLM_BACKEND=none
ANTHROPIC_API_KEY=your_anthropic_key_here

# Ollama (only needed if LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3.5:3.8b

# Auth backend database (separate from Python services)
# These match the backend/.env you need to create separately
# PORT=3000
# DB_HOST=localhost
# DB_PORT=5434
# DB_USER=user
# DB_PASSWORD=password
# DB_NAME=projectdb
# JWT_SECRET=changeme_dev_secret
# JWT_EXPIRATION=30m
